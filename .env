# === 前端配置 (Vite) ===
# 接口请求前缀，本地开发通常为 /api，生产环境可设置为后端完整地址
VITE_API_BASE_URL=/api

# Mapbox/Leaflet 地图配置（可选）
VITE_MAPBOX_TOKEN=

# === 后端配置 (Server) ===
# MongoDB 连接（本地用 mongodb://localhost:27017/sanjiangyuan）
# Vercel 部署时在 Vercel 环境变量中设置为 MongoDB Atlas 连接串
MONGODB_URI=mongodb+srv://vercel-user:123456sjy@cluster0.of4tvsc.mongodb.net/?appName=Cluster0

# JWT 密钥（生产环境请替换为随机强密钥）
JWT_SECRET=your-jwt-secret-key-change-this

# 服务器端口（仅本地开发）
PORT=3000
